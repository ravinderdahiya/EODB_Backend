generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
 
model User {
  id        Int       @id @default(autoincrement())
  fullname  String
  email     String    @unique
  password  String
  mobile    String    @unique
  role      String    @default("user")
  lastLoginIp      String?
  lastLoginLat     Float?
  lastLoginLng     Float?
  lastLoginAt      DateTime?
  loginAttempts    Int       @default(0)
  isLocked         Boolean   @default(false)
  lockedUntil      DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  // Relationship to login session logs
  sessionLogs      LoginSessionLog[]
  feedbacks        Feedback[]
}

model LoginSessionLog {
  id        Int       @id @default(autoincrement())
  userId    Int?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Session & Login tracking
  sessionId String?   // For grouping related requests in a session
  status    String?   @default("active") // active, expired, revoked, request
  loginAt   DateTime?
  expiresAt DateTime?
  revokedAt DateTime?
  
  // Location & IP tracking
  ipAddress String
  latitude  Float?
  longitude Float?
  country   String?
  city      String?
  timezone  String?
  userAgent String?
  mobile    String?   // Mobile number from request
  
  // Request details
  method    String?   // HTTP method
  url       String?   // Request URL
  responseStatus    Int?      // Response status code
  
  // Metadata
  type      String    @default("request") // "login", "request", "logout"
  createdAt DateTime  @default(now())
  
  @@index([userId])
  @@index([sessionId])
  @@index([ipAddress])
  @@index([createdAt])
  @@index([type])
  @@map("login_session_logs")
}

model Otp {
  id        String   @id @default(cuid())
  phone     String
  otp       Int
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  @@unique([phone, otp])
  @@map("otps")
}

// ✅ API URL Management Model
model ApiUrl {
  id          Int       @id @default(autoincrement())
  name        String    // Display name for the API
  url         String    // The API URL
  description String?   // Optional description
  category    String?   // Category like "auth", "user", "payment", etc.
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([category])
  @@index([isActive])
  @@map("api_urls")
}

model AnalyticsEvent {
  id            Int       @id @default(autoincrement())
  eventType     String
  category      String?
  action        String?
  label         String?
  value         Float?
  page          String?
  title         String?
  userId        Int?
  clientId      String?
  source        String    @default("frontend")
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())

  @@index([eventType])
  @@index([category])
  @@index([action])
  @@index([userId])
  @@index([createdAt])
  @@map("analytics_events")
}

model Feedback {
  id           Int       @id @default(autoincrement())
  name         String
  mobile       String?
  email        String?
  message      String
  pageUrl      String?
  status       String    @default("new")
  userId       Int?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("feedback_entries")
}

model VipUser {
  id        Int      @id @default(autoincrement())
  mobile    String   @unique
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@map("vip_users")
}
