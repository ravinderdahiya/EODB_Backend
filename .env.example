# =============================================================================
# EODB Backend — Environment Variable Reference
# Copy this file to .env and fill in REAL values before starting the server.
# .env is git-ignored. NEVER commit real secrets to version control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/eodb"

# ── Security — ALL required, server WILL NOT START if missing ─────────────────
# Minimum 32 random characters. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="REPLACE_WITH_64_RANDOM_HEX_CHARACTERS_minimum_32_chars"
JWT_SECRET="REPLACE_WITH_64_RANDOM_HEX_CHARACTERS_minimum_32_chars"

# ── SMS API (Pixabits) — ALL required ─────────────────────────────────────────
SMS_API_KEY="your-sms-api-key-from-pixabits-dashboard"
SMS_SENDER_ID="HARSAC"
SMS_TEMP_DLT_ID="your-dlt-template-id"
# ── Google Analytics ──────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID for server-side tracking
# Replace 'GA_MEASUREMENT_ID' with your actual GA4 Measurement ID from Google Analytics
# You can find this in: Admin > Data Streams > Web > Measurement ID
#GA_MEASUREMENT_ID=G-SVZY6BGEJJ
GA_MEASUREMENT_ID=G-9FFKJ7J9CL

# ── CORS — Allowed frontend origins ───────────────────────────────────────────
# Comma-separated list of allowed origins in production
# Example: ALLOWED_ORIGINS="https://hsac.org.in,https://www.hsac.org.in"
ALLOWED_ORIGINS="https://hsac.org.in"

# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" on live server. Affects cookie security + error detail level.
NODE_ENV="development"

# ── Google Analytics (optional) ───────────────────────────────────────────────
#GA_MEASUREMENT_ID="G-XXXXXXXXXX"