# =============================================================================
# EODB Backend — Environment Variable Reference
# Copy this file to .env and fill in the real values.
# .env is git-ignored; this file is committed and documents every variable.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://username:password@localhost:5432/eodb"

# ── Security ──────────────────────────────────────────────────────────────────
SESSION_SECRET="your-super-secret-session-key-change-this-in-production"
JWT_SECRET="your-jwt-secret-key-change-this-in-production"

# ── SMS API ───────────────────────────────────────────────────────────────────
SMS_API_KEY="your-sms-api-key-from-pixabits"

# ── Google Analytics ──────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID for server-side tracking
# Replace 'GA_MEASUREMENT_ID' with your actual GA4 Measurement ID from Google Analytics
# You can find this in: Admin > Data Streams > Web > Measurement ID
GA_MEASUREMENT_ID=GA_MEASUREMENT_ID